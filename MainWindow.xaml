<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WpfApp1"
        mc:Ignorable="d"
        Title="bag-problem" Height="700" Width="1190" Background="White" Foreground="Black" WindowStyle="ThreeDBorderWindow" SizeChanged="OnWindowSizeChanged">

    <Window.Resources>
        <Style x:Key="common_border" TargetType="Border">
            <Setter Property="BorderBrush" Value="Black"/>
        </Style>
        
        <Style x:Key="title" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,5,0,10"/>
        </Style>

        <Style x:Key="bottom_operator" TargetType="Button">
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="20"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Margin" Value="15,0"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
            <RowDefinition Height="auto"/>
        </Grid.RowDefinitions>

        <Border Style="{StaticResource common_border}" BorderThickness="0,0,0,1">
            <TextBlock Style="{StaticResource title}" Text="01背包问题可视化动画"/>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource common_border}" BorderThickness="0,0,0,1">
            <Grid ShowGridLines="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="235"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="物品" Margin="10,5,5,5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <TextBlock Text="物品外框颜色含义注：" Margin="50 , 5 , 5 , 5" VerticalAlignment="Center"/>
                        <TextBlock Background="Black" Width="10" Height="7" VerticalAlignment="Center"/>
                        <TextBlock Text="未使用" Margin="5 , 5 , 10 , 5" VerticalAlignment="Center"/>
                        <TextBlock Background="#FFE18000" Width="10" Height="7" VerticalAlignment="Center"/>
                        <TextBlock Text="被取出" Margin="5 , 5 , 10 , 5" VerticalAlignment="Center"/>
                        <TextBlock Background="#FF66CC00" Width="10" Height="7" VerticalAlignment="Center"/>
                        <TextBlock Text="背包中" Margin="5 , 5 , 10 , 5" VerticalAlignment="Center"/>
                        <TextBlock Background="Cyan" Width="10" Height="7" VerticalAlignment="Center"/>
                        <TextBlock Text="被放回" Margin="5 , 5 , 10 , 5" VerticalAlignment="Center"/>
                        <TextBlock Background="Red" Width="10" Height="7" VerticalAlignment="Center"/>
                        <TextBlock Text="超容量" Margin="5 , 5 , 10 , 5" VerticalAlignment="Center"/>
                    </StackPanel>

                    <Canvas x:Name="item_canvas" Margin="5,0" Grid.Row="1"></Canvas>
                </Grid>

                <Grid Grid.Column="1" ShowGridLines="True">
                    <Grid.RowDefinitions>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,0" Height="55">
                        <StackPanel VerticalAlignment="Center">
                            <Button x:Name="add_item_button" Content="添加物品" VerticalAlignment="Center" Margin="0,0,0,5" Click="add_item" Height="20" Width="55"/>
                            <Button x:Name="random_item_button" Content="随机给定" VerticalAlignment="Center" Click="random_set_item" Height="20" Width="55"/>
                        </StackPanel>
                        <StackPanel Margin="10,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Margin="0 1 0 4">
                                <TextBlock Width="30" TextAlignment="Center"><Run Language="zh-cn" Text="价值"/><Run Text=":"/></TextBlock>
                                <TextBox x:Name="value_text" Width="35" TextWrapping="Wrap" Margin="5,0,0,0"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0 4 0 0">
                                <TextBlock Width="30" TextAlignment="Center"><Run Language="zh-cn" Text="重量"/><Run Text=":"/></TextBlock>
                                <TextBox x:Name="weight_text" Width="35" TextWrapping="Wrap" Margin="5,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center"  Margin="10,0" Height="30">
                        <Button x:Name="random_gen_button" Content="随机生成" VerticalAlignment="Center" Click="random_gen" Height="20" Width="55"/>
                        <StackPanel Margin="10,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="30" TextAlignment="Center" Text="数量:"/>
                                <TextBox x:Name="item_num_text" Width="35" TextWrapping="Wrap" Margin="5,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="2" Orientation="Horizontal" Height="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="随机数偏" VerticalAlignment="Center"/>
                        <TextBlock Text="小" Margin="5,0,5,0" VerticalAlignment="Center"/>
                        <Slider Width="95" VerticalAlignment="Center" Value="3" Minimum="1" Maximum="10" TickPlacement="BottomRight" TickFrequency="1" ValueChanged="random_gen_tendency"/>
                        <TextBlock Text="大" Margin="5,0,5,0" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center"  Margin="10,0" Height="30">
                        <Button x:Name="delete_item_button" Content="删除物品" VerticalAlignment="Center" Click="delete_item" Height="20" Width="55"/>
                        <StackPanel Margin="10,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="30" TextAlignment="Center" Text="ID:"/>
                                <TextBox x:Name="ID_text" Width="35" TextWrapping="Wrap" Margin="5,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <Grid Grid.Row="4" ShowGridLines="True" Height="40">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="suffle_item_button" Content="打乱" VerticalAlignment="Center" Click="suffle_item" Margin="8,0,8,0" Height="22" Width="40"/>

                        <Grid Grid.Column="1">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                                <ColumnDefinition/>
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition/>
                                <RowDefinition/>
                            </Grid.RowDefinitions>

                            <Button Grid.RowSpan="2" x:Name="sort_item_button" Content="排序" VerticalAlignment="Center" Click="sort_item" Height="22" Width="40"/>

                            <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                                <CheckBox x:Name="sort_by_value_check_box" Margin="0,0,2,0" Checked="sortByValueChecked" Unchecked="sortByValueUnchecked"/>
                                <TextBlock x:Name="sort_by_value_text" Text="价值" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                                <CheckBox x:Name="sort_by_weight_check_box" Margin="0,0,2,0" Checked="sortByWeightChecked" Unchecked="sortByWeightUnchecked"/>
                                <TextBlock x:Name="sort_by_weight_text" Text="重量" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Row="0" Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                                <CheckBox x:Name="sort_by_effective_check_box" Margin="0,0,2,0" Checked="sortByEffectiveChecked" Unchecked="sortByEffectiveUnchecked"/>
                                <TextBlock x:Name="sort_by_effective_text" Text="性价比" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Grid.Row="1" Grid.Column="2" HorizontalAlignment="Left" VerticalAlignment="Center" Orientation="Horizontal">
                                <CheckBox x:Name="sort_by_positive_sequence_check_box" Margin="0,0,2,0"/>
                                <TextBlock Text="正序" FontSize="11"/>
                            </StackPanel>
                        </Grid>
                    </Grid>

                    <Grid Grid.Row="5" ShowGridLines="True" Height="35">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>

                        <Button x:Name="renumber_item_button" Content="重新编号" Grid.Column="0"  Height="22" Width="70" Click="renumber_item"/>
                        <Button x:Name="clear_item_button" Content="清空物品" Grid.Column="1"  Click="clear_item" Height="22" Width="70"/>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="2" Style="{StaticResource common_border}" BorderThickness="0,0,0,1">
            <Grid ShowGridLines="True">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition Width="auto"/>
                </Grid.ColumnDefinitions>

                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                    </Grid.RowDefinitions>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="背包" Margin="15,5,5,5" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                        <StackPanel Grid.Column="1" Orientation="Horizontal"  VerticalAlignment="Center" HorizontalAlignment="Left" >
                            <TextBlock Margin="15,5,3,5" FontSize="12" VerticalAlignment="Center"><Run Text="跳过"/><Run Language="zh-cn" Text="超额"/><Run Text="装载"/></TextBlock>
                            <CheckBox x:Name="skip_item_over_capacity_check_box" Margin="1,5,1,5" VerticalAlignment="Center" Checked="skipItemOverCapacityChecked" Unchecked="skipItemOverCapacityUnchecked"/>
                            <TextBlock Text="装满后继续尝试" Margin="15,5,3,5" FontSize="12" VerticalAlignment="Center"/>
                            <CheckBox x:Name="keep_try_after_full_fill_check_box" Margin="1,5,1,5" VerticalAlignment="Center" Checked="keepTryAfterFullFillChecked" Unchecked="keepTryAfterFullFillUnchecked"/>
                            <TextBlock Margin="15,5,3,5" FontSize="12" VerticalAlignment="Center"><Run Text="使用记录法"/><Run Text="去除重复计算"/></TextBlock>
                            <CheckBox x:Name="use_table_to_reduce_step_check_box" Margin="1,5,1,5" VerticalAlignment="Center" IsChecked="True" Checked="useTableToReduceStepChecked" Unchecked="useTableToReduceStepUnchecked"/>
                            <TextBlock Margin="15,5,3,5" FontSize="12" VerticalAlignment="Center"><Run Text="总容量大于"/><Run Text="未选物品重量时使用一次性装填"/></TextBlock>
                            <CheckBox x:Name="disposable_fill_while_capacity_enough_check_box" Margin="1,5,15,5" VerticalAlignment="Center" IsChecked="True" Checked="disposableFillWhileCapacityEnoughChecked" Unchecked="disposableFillWhileCapacityEnoughUnchecked"/>
                        </StackPanel>
                    </Grid>
                    <TextBlock Grid.Row="1" Text="当前背包状况：" Margin="15,0,5,0" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                    <Canvas x:Name="bag_canvas" Grid.Row="2" Margin="5,0"></Canvas>
                    <TextBlock Grid.Row="3" Text="装载最高价值时背包状况：" Margin="15,0,5,0" FontWeight="Bold" FontSize="14"/>
                    <Canvas x:Name="bag_max_value_canvas" Grid.Row="4" Margin="5,0"></Canvas>
                    <StackPanel Grid.Row="5" Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="在 [剩余背包容量 , 剩余物品个数]=[" Margin="15,0,1,0" FontWeight="Bold" FontSize="14"/>
                        <TextBox x:Name="left_capacity_search_text" Width="22" Height="15" Text="" TextAlignment="Center" KeyDown="max_value_saerch" LostFocus="max_value_saerch"/>
                        <TextBlock Text="," Margin="1,0,1,0"  FontWeight="Bold" FontSize="14"/>
                        <TextBox x:Name="left_item_num_search_text" Width="22" Height="15" Text="" TextAlignment="Center" KeyDown="max_value_saerch" LostFocus="max_value_saerch"/>
                        <TextBlock Text="] 情况下记录的最大价值状况：" Margin="1,0,0,0"  FontWeight="Bold" FontSize="14"/>
                    </StackPanel>
                    <Canvas x:Name="max_value_record_canvas" Grid.Row="6" Margin="5,0"></Canvas>
                </Grid>

                <Grid Grid.Column="1" ShowGridLines="True" Width="240">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="auto"/>
                        <RowDefinition/>
                        <RowDefinition Height="auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,0" Height="50" HorizontalAlignment="Center">
                        <Button x:Name="change_capacity_button" Content="更改背包容量" Height="21" Width="89" VerticalAlignment="Center" Click="change_capacity"/>
                        <StackPanel Margin="10,0" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Width="40" TextAlignment="Center" FontSize="14" Text="容量:"/>
                                <TextBox x:Name="capacity_text" Width="35" TextWrapping="Wrap" Margin="5,0,0,0"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Margin="10,0">
                        <TextBlock Text="步骤解释:" Margin="0,5,0,5" FontSize="14" FontWeight="Bold"/>
                        <TextBlock x:Name="explain_text" FontSize="13" LineHeight="18"  Text="" TextWrapping="Wrap" Margin="0,0,0,5"/>
                    </StackPanel>

                    <Grid Grid.Row="2" Margin="5,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="auto"/>
                            <ColumnDefinition/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                            <RowDefinition Height="30"/>
                        </Grid.RowDefinitions>

                        <StackPanel Orientation="Horizontal" Margin="0,1" Grid.Column="0" Grid.Row="0">
                            <TextBlock Text="最高价值:" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="max_value_text"  Text="" Width="40" TextAlignment="Center"  VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,1" Grid.Column="0" Grid.Row="1">
                            <TextBlock Text="目前价值:" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="precent_value_text"  Text="" Width="40" TextAlignment="Center"  VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,1" Grid.Column="0" Grid.Row="2">
                            <TextBlock Text="剩余容量:" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="left_capacity_text"  Text="" Width="40" TextAlignment="Center"  VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,1" Grid.Column="1" Grid.Row="0">
                            <TextBlock Text="未选物品数量:" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="left_item_num_text"  Text="" Width="40" TextAlignment="Center"  VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,1" Grid.Column="1" Grid.Row="1">
                            <TextBlock Text="未选物品价值:" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="left_item_value_text"  Text="" Width="40" TextAlignment="Center"  VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Margin="0,1" Grid.Column="1" Grid.Row="2">
                            <TextBlock Text="未选物品重量:" VerticalAlignment="Center" FontWeight="Bold" FontSize="14"/>
                            <TextBlock x:Name="left_item_weight_text"  Text="" Width="40" TextAlignment="Center"  VerticalAlignment="Center" FontSize="14"/>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Grid>
        </Border>

        <StackPanel Grid.Row="3" Height="40" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button x:Name="reset_button" Style="{StaticResource bottom_operator}" Content="重置" Click="reset_animation"/>
            <Button x:Name="last_order_button" Style="{StaticResource bottom_operator}" Content="上一步" Click="to_last_step"/>
            <Button x:Name="start_button" Style="{StaticResource bottom_operator}" Content="开始" Click="start"/>
            <Button x:Name="next_order_button" Style="{StaticResource bottom_operator}" Content="下一步" Click="to_next_step"/>
            <Button x:Name="end_button" Style="{StaticResource bottom_operator}" Content="结束" Click="to_end"/>
            <StackPanel Height="20" Orientation="Horizontal" HorizontalAlignment="Center" Margin="10,0,0,0">
                <TextBlock FontSize="13" VerticalAlignment="Center" ><Run Language="zh-cn" Text="倍"/><Run Text="速："/></TextBlock>
                <TextBox x:Name="change_speed_text_box" Width="25" Text="1" TextAlignment="Center" LostFocus="change_speed" KeyDown="change_speed"/>
            </StackPanel>
        </StackPanel>
        <Button Grid.Row="3" x:Name="debug_button" Style="{StaticResource bottom_operator}" Margin="1000, 0 , 0, 0" Content="调试" Click="debug" Visibility="Collapsed"/>
    </Grid>
</Window>
